---
# The API service — depends on postgres being ready.
# The initContainer blocks startup until postgres accepts connections,
# modeling a real app that would fail to boot without its database.
apiVersion: apps/v1
kind: Deployment
metadata:
  name: api
  namespace: {{ namespace }}
  labels:
    app: api
    pr: "{{ pr_number }}"
spec:
  replicas: 1
  selector:
    matchLabels:
      app: api
  template:
    metadata:
      labels:
        app: api
    spec:
      initContainers:
        # Waits for Postgres to be ready before the main container starts.
        # Replace with a real migration job (e.g. `alembic upgrade head`) in production.
        - name: wait-for-postgres
          image: busybox:1.36
          command:
            - sh
            - -c
            - |
              echo "Waiting for postgres..."
              until nc -z postgres 5432; do
                sleep 2
              done
              echo "Postgres is up!"

      containers:
        - name: api
          # hashicorp/http-echo is a stand-in; replace with your real API image.
          # It echoes a configurable string so you can verify routing works.
          image: hashicorp/http-echo:latest
          args:
            - "-text=Hello from PR #{{ pr_number }} (sha={{ image_tag }})"
            - "-listen=:5678"
          ports:
            - containerPort: 5678
          env:
            - name: PR_NUMBER
              value: "{{ pr_number }}"
          envFrom:
            - secretRef:
                name: postgres-credentials
          readinessProbe:
            httpGet:
              path: /
              port: 5678
            initialDelaySeconds: 3
            periodSeconds: 5
          resources:
            requests:
              cpu: "25m"
              memory: "32Mi"
            limits:
              cpu: "100m"
              memory: "64Mi"

---
apiVersion: v1
kind: Service
metadata:
  name: api
  namespace: {{ namespace }}
spec:
  selector:
    app: api
  ports:
    - port: 80
      targetPort: 5678
