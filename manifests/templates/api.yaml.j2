---
# The API service — depends on postgres being ready.
# The initContainer blocks startup until postgres accepts connections,
# modeling a real app that would fail to boot without its database.
apiVersion: apps/v1
kind: Deployment
metadata:
  name: api
  namespace: {{ namespace }}
  labels:
    app: api
    pr: "{{ pr_number }}"
spec:
  replicas: 1
  selector:
    matchLabels:
      app: api
  template:
    metadata:
      labels:
        app: api
    spec:
      initContainers:
        # Waits for Postgres to be ready before the main container starts.
        # Replace with a real migration job (e.g. `alembic upgrade head`) in production.
        - name: wait-for-postgres
          image: busybox:1.36
          command:
            - sh
            - -c
            - |
              echo "Waiting for postgres..."
              until nc -z postgres 5432; do
                sleep 2
              done
              echo "Postgres is up!"

      containers:
        - name: api
          image: {{ api.image }}
          args:
            - "-text=Hello from PR #{{ pr_number }} (sha={{ image_tag }})"
            - "-listen=:{{ api.port }}"
          ports:
            - containerPort: {{ api.port }}
          env:
            - name: PR_NUMBER
              value: "{{ pr_number }}"
          envFrom:
            - secretRef:
                name: postgres-credentials
          readinessProbe:
            httpGet:
              path: /
              port: {{ api.port }}
            initialDelaySeconds: 3
            periodSeconds: 5
          resources:
            requests:
              cpu: "{{ api.resources.requests.cpu }}"
              memory: "{{ api.resources.requests.memory }}"
            limits:
              cpu: "{{ api.resources.limits.cpu }}"
              memory: "{{ api.resources.limits.memory }}"

---
apiVersion: v1
kind: Service
metadata:
  name: api
  namespace: {{ namespace }}
spec:
  selector:
    app: api
  ports:
    - port: 80
      targetPort: {{ api.port }}
